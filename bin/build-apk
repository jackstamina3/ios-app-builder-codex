#!/usr/bin/env bash
set -euo pipefail

usage() { echo "Usage: bin/build-apk targets/android/OWNER__REPOSITORY__SHORT_SHA__PROFILE.json" >&2; exit 64; }
[[ $# == 1 ]] || usage
target="$1"
[[ "$target" =~ ^targets/android/[A-Za-z0-9_.-]+\.json$ && "$target" != *..* ]] || usage
root="$(git rev-parse --show-toplevel)"
cd "$root"
python3 scripts/validate_android_target.py "$target" >/dev/null
gh auth status --hostname github.com >/dev/null

remote_url="$(git remote get-url origin)"
repo="$(sed -E 's#^(https://github.com/|git@github.com:)##; s#\.git$##' <<<"$remote_url")"
[[ "$repo" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]] || { echo "Cannot derive GitHub repository from origin" >&2; exit 1; }
[[ "$(gh repo view "$repo" --json visibility --jq .visibility)" == PUBLIC ]] || {
  echo "Builder repository must be public for free GitHub-hosted runners" >&2; exit 1;
}
[[ -z "$(git status --porcelain)" ]] || { echo "Working tree must be clean" >&2; exit 1; }
head_sha="$(git rev-parse HEAD)"
git fetch origin main
remote_sha="$(git rev-parse origin/main)"
[[ "$head_sha" == "$remote_sha" ]] || { echo "Local HEAD must equal origin/main" >&2; exit 1; }

request_id="$(python3 -c 'import uuid; print(uuid.uuid4())')"
started="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
payload="$(jq -n --arg ref main --arg target "$target" --arg request_id "$request_id" \
  '{ref:$ref,inputs:{target:$target,request_id:$request_id}}')"
response="$(printf '%s' "$payload" | gh api --method POST -H 'X-GitHub-Api-Version: 2026-03-10' \
  "repos/$repo/actions/workflows/build-android-apk.yml/dispatches" --input -)"
run_id="$(jq -r '.workflow_run_id // empty' <<<"$response")"
if [[ -z "$run_id" ]]; then
  for _ in {1..30}; do
    run_id="$(gh run list --repo "$repo" --workflow build-android-apk.yml --event workflow_dispatch --limit 30 \
      --json databaseId,displayTitle,createdAt,headSha \
      --jq ".[] | select(.displayTitle | contains(\"$request_id\")) | select(.headSha == \"$head_sha\") | select(.createdAt >= \"$started\") | .databaseId" | head -n1)"
    [[ -n "$run_id" ]] && break
    sleep 2
  done
fi
[[ "$run_id" =~ ^[0-9]+$ ]] || { echo "Could not correlate workflow run for $request_id" >&2; exit 1; }

if ! gh run watch "$run_id" --repo "$repo" --exit-status --compact; then
  gh run view "$run_id" --repo "$repo" --log-failed || true
  mkdir -p "dist/$request_id/diagnostics"
  gh run download "$run_id" --repo "$repo" --name "android-build-diagnostics-$request_id" \
    --dir "dist/$request_id/diagnostics" || true
  echo "Build failed; diagnostics: $root/dist/$request_id/diagnostics" >&2
  exit 1
fi

destination="$root/dist/$request_id"
mkdir -p "$destination"
gh run download "$run_id" --repo "$repo" --name "test-signed-apk-$request_id" --dir "$destination"
one_file() {
  local pattern="$1" list="$destination/.file-list"
  find "$destination" -type f -name "$pattern" -print > "$list"
  [[ "$(wc -l < "$list" | tr -d ' ')" == 1 ]] || { echo "Expected exactly one $pattern" >&2; exit 1; }
  sed -n '1p' "$list"
}
apk="$(one_file '*.test-signed.apk')"
checksums="$(one_file SHA256SUMS)"
manifest="$(one_file build-manifest.json)"
verification="$(one_file fresh-verification.json)"
(cd "$(dirname "$checksums")" && shasum -a 256 -c "$(basename "$checksums")")
python3 scripts/verify_android_apk.py "$apk" "$root/$target" --portable-only \
  --output "$destination/local-portable-verification.json" >/dev/null
python3 - "$root/$target" "$apk" "$manifest" "$verification" <<'PY'
import hashlib, json, pathlib, sys
target_path, apk_path, manifest_path, verification_path = map(pathlib.Path, sys.argv[1:])
target = json.loads(target_path.read_text())
manifest = json.loads(manifest_path.read_text())
verification = json.loads(verification_path.read_text())
digest = hashlib.sha256(apk_path.read_bytes()).hexdigest()
if manifest.get("status") != "verified_test_signed_fire_tv_apk":
    raise SystemExit("artifact manifest is not fully verified")
if manifest.get("artifact", {}).get("sha256") != digest or verification.get("sha256") != digest:
    raise SystemExit("downloaded APK digest is not bound to fresh verification")
if manifest.get("source", {}).get("commit") != target["source"]["commit"]:
    raise SystemExit("artifact source commit does not match selected target")
if verification.get("status") != "verified_test_signed_fire_tv_apk":
    raise SystemExit("fresh verification report is incomplete")
PY
digest="$(shasum -a 256 "$apk" | awk '{print $1}')"
printf 'Test-signed APK: %s\nSHA-256: %s\nRequest ID: %s\nRun ID: %s\nLocal check: safe-archive and ABI verification passed; full signing/TV verification passed on a fresh runner.\n' \
  "$apk" "$digest" "$request_id" "$run_id"
