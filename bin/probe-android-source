#!/usr/bin/env bash
set -euo pipefail

usage() { echo "Usage: bin/probe-android-source OWNER/REPOSITORY REF" >&2; exit 64; }
[[ $# == 2 ]] || usage
source_repo="$1"
source_ref="$2"
[[ "$source_repo" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]] || usage
[[ "$source_ref" =~ ^[A-Za-z0-9][A-Za-z0-9._/+@-]{0,199}$ && "$source_ref" != *..* && "$source_ref" != *@\{* ]] || usage
gh auth status --hostname github.com >/dev/null
source_commit="$(gh api "repos/$source_repo/commits/$source_ref" --jq .sha)"
[[ "$source_commit" =~ ^[0-9a-f]{40}$ ]] || { echo "Could not resolve immutable source commit" >&2; exit 1; }

root="$(git rev-parse --show-toplevel)"
cd "$root"
[[ -z "$(git status --porcelain)" ]] || { echo "Working tree must be clean" >&2; exit 1; }
head_sha="$(git rev-parse HEAD)"
git fetch origin main
[[ "$head_sha" == "$(git rev-parse origin/main)" ]] || { echo "Local HEAD must equal origin/main" >&2; exit 1; }
remote_url="$(git remote get-url origin)"
repo="$(sed -E 's#^(https://github.com/|git@github.com:)##; s#\.git$##' <<<"$remote_url")"
request_id="$(python3 -c 'import uuid; print(uuid.uuid4())')"
started="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
payload="$(jq -n --arg ref main --arg repository "$source_repo" --arg source_ref "$source_ref" \
  --arg source_commit "$source_commit" --arg request_id "$request_id" \
  '{ref:$ref,inputs:{source_repository:$repository,source_ref:$source_ref,source_commit:$source_commit,request_id:$request_id}}')"
response="$(printf '%s' "$payload" | gh api --method POST -H 'X-GitHub-Api-Version: 2026-03-10' \
  "repos/$repo/actions/workflows/probe-android-source.yml/dispatches" --input -)"
run_id="$(jq -r '.workflow_run_id // empty' <<<"$response")"
if [[ -z "$run_id" ]]; then
  for _ in {1..30}; do
    run_id="$(gh run list --repo "$repo" --workflow probe-android-source.yml --event workflow_dispatch --limit 30 \
      --json databaseId,displayTitle,createdAt,headSha \
      --jq ".[] | select(.displayTitle | contains(\"$request_id\")) | select(.headSha == \"$head_sha\") | select(.createdAt >= \"$started\") | .databaseId" | head -n1)"
    [[ -n "$run_id" ]] && break
    sleep 2
  done
fi
[[ "$run_id" =~ ^[0-9]+$ ]] || { echo "Could not correlate Android probe run" >&2; exit 1; }
gh run watch "$run_id" --repo "$repo" --exit-status --compact
destination="$root/probe-output/android/$request_id"
mkdir -p "$destination"
gh run download "$run_id" --repo "$repo" --name "android-probe-$request_id" --dir "$destination"
report="$(find "$destination" -type f -name android-probe-report.json -print -quit)"
python3 -m json.tool "$report"
printf 'Android probe report: %s\nSource commit: %s\n' "$report" "$source_commit"
